{
  "manifest_version": 3,
  "name": "OpenAdBlock",
  "description": "A lightweight, open-source ad blocker with breakage-free filters, built for fast and stable browsing.",
  "version": "0.1.0",
  "minimum_chrome_version": "121",
  "icons": {
    "16": "src/assets/icon16.png",
    "32": "src/assets/icon32.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "action": {
    "default_title": "OpenAdBlock",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/icon16.png",
      "32": "src/assets/icon32.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "permissions": [
    "alarms",
    "activeTab",
    "declarativeNetRequest",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "openadblock_static_main",
        "enabled": true,
        "path": "src/rules/static-rules.json"
      },
      {
        "id": "openadblock_static_allowlist",
        "enabled": true,
        "path": "src/rules/allowlist-rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/cosmetic.js"
      ],
      "run_at": "document_start"
    }
  ]
}
