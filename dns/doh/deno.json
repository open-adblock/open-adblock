{
  "tasks": {
    "test": "deno test --allow-read --allow-net src/",
    "test:integration": "deno test --allow-read --allow-net --allow-env tests/",
    "fmt": "deno fmt src/ tests/",
    "lint": "deno lint src/ tests/"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window"],
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "imports": {
    "std/": "https://deno.land/std@0.224.0/"
  }
}
