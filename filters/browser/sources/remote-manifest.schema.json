{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/open-adblock/open-adblock@main/filters/browser/sources/remote-manifest.schema.json",
  "title": "OpenAdBlock Remote Filter Manifest",
  "type": "object",
  "required": ["schemaVersion", "version", "files"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "publishedAt": {
      "type": "string"
    },
    "minimumExtensionVersion": {
      "type": "string"
    },
    "reportEndpointUrl": {
      "type": "string",
      "format": "uri"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "url"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["network", "allowlist-network", "cosmetic", "allowlist-cosmetic"]
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "license": {
            "type": "string"
          },
          "revision": {
            "type": "string"
          }
        }
      }
    }
  }
}
